@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(AdaSDFCL_VERSION_STRING "@ADASDF_CL_VERSION_STRING@")
set(AdaSDFCL_HAS_RUNTIME @ADASDF_CL_INSTALL_RUNTIME_TARGET@)
set(AdaSDFCL_HAS_EXISTING_CORE @ADASDF_CL_HAS_EXISTING_CORE@)
set(AdaSDFCL_HAS_CUDA_BACKEND @ADASDF_CL_INSTALL_HAS_CUDA_BACKEND@)

if(AdaSDFCL_HAS_EXISTING_CORE)
  find_dependency(Eigen3 CONFIG)
  find_dependency(nlohmann_json CONFIG)
  find_dependency(fmt CONFIG)
endif()

if(AdaSDFCL_HAS_CUDA_BACKEND)
  find_dependency(CUDAToolkit)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/AdaSDFCLTargets.cmake")

check_required_components(AdaSDFCL)
