{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adasdf.structure.v1",
  "title": "AdaSDF-CL Structure JSON v1",
  "type": "object",
  "required": ["schema_id", "schema_version", "adasdf_version", "tool_name", "generated_at_utc", "status", "status_code", "success", "warnings", "model_type", "bounds", "blocks", "levels"],
  "properties": {
    "schema_id": {"const": "adasdf.structure.v1"},
    "schema_version": {"const": 1},
    "adasdf_version": {"type": "string"},
    "tool_name": {"type": "string"},
    "generated_at_utc": {"type": "string"},
    "status": {"enum": ["ok", "warning", "error"]},
    "status_code": {"type": "string"},
    "success": {"type": "boolean"},
    "warnings": {"type": "array"},
    "model_type": {"type": "string"},
    "bounds": {"type": "object"},
    "blocks": {"type": "array"},
    "levels": {"type": "array"}
  }
}
