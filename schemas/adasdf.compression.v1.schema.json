{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adasdf.compression.v1",
  "title": "AdaSDF-CL Compression JSON v1",
  "type": "object",
  "required": ["schema_id", "schema_version", "adasdf_version", "tool_name", "generated_at_utc", "status", "status_code", "success", "warnings", "model_type", "block_counts", "rank_stats", "memory", "compression_ratio", "error_summary"],
  "properties": {
    "schema_id": {"const": "adasdf.compression.v1"},
    "schema_version": {"const": 1},
    "adasdf_version": {"type": "string"},
    "tool_name": {"type": "string"},
    "generated_at_utc": {"type": "string"},
    "status": {"enum": ["ok", "warning", "error"]},
    "status_code": {"type": "string"},
    "success": {"type": "boolean"},
    "warnings": {"type": "array"},
    "model_type": {"type": "string"},
    "block_counts": {"type": "object"},
    "rank_stats": {"type": "object"},
    "memory": {"type": "object"},
    "compression_ratio": {"type": "number"},
    "error_summary": {"type": "object"}
  }
}
