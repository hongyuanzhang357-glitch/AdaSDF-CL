{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adasdf.build_profile.v1",
  "title": "AdaSDF-CL Build Profile JSON v1",
  "type": "object",
  "required": ["schema_id", "schema_version", "adasdf_version", "tool_name", "generated_at_utc", "status", "status_code", "success", "warnings", "profile_status", "timings", "counters"],
  "properties": {
    "schema_id": {"const": "adasdf.build_profile.v1"},
    "schema_version": {"const": 1},
    "adasdf_version": {"type": "string"},
    "tool_name": {"type": "string"},
    "generated_at_utc": {"type": "string"},
    "status": {"enum": ["ok", "warning", "error"]},
    "status_code": {"type": "string"},
    "success": {"type": "boolean"},
    "warnings": {"type": "array"},
    "profile_status": {"enum": ["completed", "timeout", "failed"]},
    "timings": {
      "type": "object",
      "properties": {
        "cache_lookup_time_ms": {"type": "number"},
        "cache_insert_time_ms": {"type": "number"},
        "deduplication_time_ms": {"type": "number"},
        "marker_cache_time_ms": {"type": "number"}
      }
    },
    "counters": {
      "type": "object",
      "properties": {
        "sample_cache_enabled": {"type": "boolean"},
        "num_adaptive_tree_nodes": {"type": "integer"},
        "num_adaptive_leaf_blocks": {"type": "integer"},
        "uniform_max_level_leaf_count": {"type": "integer"},
        "total_logical_node_count": {"type": "integer"},
        "uniform_max_level_logical_node_count": {"type": "integer"},
        "adaptive_tree_sparsity_ratio": {"type": "number"},
        "sample_cache_scope": {"enum": ["off", "block", "global"]},
        "sample_cache_entries": {"type": "integer"},
        "sample_cache_hits": {"type": "integer"},
        "sample_cache_misses": {"type": "integer"},
        "sample_cache_hit_rate": {"type": "number"},
        "distance_cache_hits": {"type": "integer"},
        "distance_cache_misses": {"type": "integer"},
        "sign_cache_hits": {"type": "integer"},
        "sign_cache_misses": {"type": "integer"},
        "corner_cache_hits": {"type": "integer"},
        "corner_cache_misses": {"type": "integer"},
        "block_point_duplicate_count": {"type": "integer"},
        "marker_candidate_cache_hits": {"type": "integer"},
        "marker_candidate_cache_misses": {"type": "integer"},
        "marker_decision_cache_hits": {"type": "integer"},
        "marker_decision_cache_misses": {"type": "integer"},
        "distance_queries_saved": {"type": "integer"},
        "sign_queries_saved": {"type": "integer"},
        "box_triangle_distance_saved": {"type": "integer"},
        "cache_memory_estimate_bytes": {"type": "integer"}
      }
    },
    "adaptive_tree": {
      "type": "object",
      "properties": {
        "min_level": {"type": "integer"},
        "max_level": {"type": "integer"},
        "block_resolution": {"type": "integer"},
        "leaf_count_by_level": {"type": "array"},
        "internal_count_by_level": {"type": "array"},
        "refined_count_by_level": {"type": "array"},
        "far_field_leaf_count_by_level": {"type": "array"},
        "contact_band_leaf_count_by_level": {"type": "array"},
        "near_surface_leaf_count_by_level": {"type": "array"},
        "logical_node_count_by_level": {"type": "array"},
        "exact_node_count_by_level": {"type": "array"},
        "predicted_node_count_by_level": {"type": "array"},
        "theoretical_uniform_leaf_blocks_at_max_level": {"type": "integer"},
        "theoretical_uniform_logical_nodes_at_max_level": {"type": "integer"},
        "leaf_sparsity_ratio": {"type": "number"},
        "logical_node_sparsity_ratio": {"type": "number"},
        "appears_uniform_max_level": {"type": "boolean"},
        "mixed_level_leaves_present": {"type": "boolean"},
        "levels": {"type": "array"}
      }
    }
  }
}
